classDiagram
    class DType {
        <<enumeration>>
        FP4
        FP8_e5m2
        FP8_e4m3
        BF16
        FP16
        FP32
        FP64
    }
    class DeviceType {
        <<enumeration>>
        NONE
        HOST
        DEVICE
    }
    class Device {
        +type_ DeviceType
        +index_ int
    }
    namespace Memory {
        class Storage {
            +void* ptr
        }
        class IAllocator {
            +allocate(uint64_t size) void**
            +deallocate(void* ptr) void*
        }
        class CPUAllocator {
            +allocate(uint64_t size) void*
            +deallocate(void* ptr) void
        }
        class CUDAAllocator {
            +allocate(uint64_t size) void *
            +deallocate(void* ptr) void*
        }
        class AllocatorAdapter {
            +allocate(uint64_t size) void*
            +deallocate() void
            -IAllocator* allocator_
        }
        class MemoryPool {
            -Allocator alloc_;
        }
    }
    namespace core {
        class StorageImpl {
            -unique_ptr~Storage~ data_
            -BaseAllocator~T~ allocator_
            -uint64_t total_bytes
        }

