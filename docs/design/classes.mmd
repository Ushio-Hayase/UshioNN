            +contiguous() const
            +to(Device location) Tensor
            +to(DType type) Tensor
            +cpu() Tensor
            +cuda() Tensor
            +operator+=(const Tensor& other) Tensor&
            +operator*=(const float scalar) Tensor&
            +shape() const vector~uint64_t~
            +strides() const vector~uint64_t~
            +dim() uint64_t
            +numel() uint64_t
            +dtype() DType
            +device() Device
            +is_contiguous() bool
            +get_elem_size() uint64_t
            +data() void*
            +data_ptr~T~() T*
            -clone_cpu() Tensor
            -clone_gpu() Tensor
            -shared_ptr~TensorImpl~ impl_
        }
        class TensorImpl {
            +TensorImpl(vector~uint64_t~ shape, DType type, Device location)
            +TensorImpl(shared_ptr~StorageImpl~ storage, vector~uint64_t~ shape, vector~uint64_t~ strides, uint64_t offset, DType type)
